@using Microsoft.Extensions.Options
@using PortfolioSite.Models
@inject IOptions<SiteModeOptions> SiteModeOptions

@{
    var title = ViewData["Title"] as string ?? "Harmen van der Meijden";
    var description = ViewData["Description"] as string ?? "Portfolio van Harmen van der Meijden.";
    var canonical = ViewData["Canonical"] as string ?? "https://www.harmenvandermeijden.nl/";
    var ogTitle = ViewData["OgTitle"] as string ?? title;
    var ogDescription = ViewData["OgDescription"] as string ?? description;
    var ogImage = ViewData["OgImage"] as string ?? "https://www.harmenvandermeijden.nl/assets/social/og-harmen-site-v2.png";
    var structuredData = ViewData["StructuredData"] as string;
    var hideZzpMeuk = SiteModeOptions.Value.HideZzpMeuk;
}
<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title</title>
    <meta name="description" content="@description" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#faf7ee" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="nl_NL" />
    <meta property="og:title" content="@ogTitle" />
    <meta property="og:description" content="@ogDescription" />
    <meta property="og:image" content="@ogImage" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content="Portret van Harmen van der Meijden" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@ogTitle" />
    <meta name="twitter:description" content="@ogDescription" />
    <meta name="twitter:image" content="@ogImage" />
    <meta name="twitter:image:alt" content="Portret van Harmen van der Meijden" />
    <link rel="canonical" href="@canonical" />
    <link rel="icon" href="~/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@400;500;600;700;800&family=Newsreader:opsz,wght@6..72,500;6..72,700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/styles.css" asp-append-version="true" />
    @if (!string.IsNullOrWhiteSpace(structuredData))
    {
        <script type="application/ld+json">
            @Html.Raw(structuredData)
        </script>
    }
</head>
<body>
    <canvas id="site-bg-canvas" aria-hidden="true"></canvas>
    <header class="site-header shared-header">
        <div class="container">
            <div class="header-row">
                <a class="brand" href="/" aria-label="Ga naar home">
                    <span class="brand-mark">H</span>
                    <span class="brand-text">
                        <strong>Harmen van der Meijden</strong>
                        <span>Product, software en operatie</span>
                    </span>
                </a>
                <button
                    class="mobile-nav-toggle"
                    type="button"
                    aria-expanded="false"
                    aria-controls="site-menu"
                    aria-label="Open navigatiemenu">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
                <div class="header-actions" id="site-menu">
                    <nav class="site-nav" aria-label="Hoofdnavigatie">
                        <a class="header-link" href="/">Home</a>
                        <a class="header-link" href="/#cv">CV</a>
                        <a class="header-link" href="https://linkedin.com/in/harmen-van-der-meijden" target="_blank" rel="noopener noreferrer">LinkedIn</a>
                        @if (!hideZzpMeuk)
                        {
                            <details class="nav-dropdown">
                                <summary class="header-link">Verdieping</summary>
                                <div class="nav-dropdown-menu">
                                    <a class="nav-dropdown-link" href="/disc">DISC-resultaten</a>
                                    <a class="nav-dropdown-link" href="/api-koppelingen">API-koppelingen</a>
                                    <a class="nav-dropdown-link" href="/ai-integratie">AI-integratie</a>
                                    <a class="nav-dropdown-link" href="/change-management">Change management</a>
                                </div>
                            </details>
                        }
                        <a class="header-link" href="/#contact">Contact</a>
                    </nav>
                </div>
            </div>
        </div>
    </header>
    @RenderBody()
    <script src="~/script.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
